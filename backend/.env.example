# on your Mark! - Backend Environment Configuration
# Copy this file to .env and fill in the values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Cognito
USER_POOL_ID=
USER_POOL_CLIENT_ID=
IDENTITY_POOL_ID=

# AppSync
APPSYNC_ENDPOINT=
API_KEY=

# S3 Buckets
MEDIA_BUCKET=
ROUTES_BUCKET=

# SNS Topics
EMERGENCY_TOPIC_ARN=
AWOL_TOPIC_ARN=
LOCATION_PING_TOPIC_ARN=

# External Services
MAPBOX_ACCESS_TOKEN=

# Firebase (for push notifications on Android)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Agora (for voice chat)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Analytics
PINPOINT_APP_ID=
